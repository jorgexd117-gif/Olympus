# Environment variables
# Copy this file to .env and customize values

# Persistent storage
AGENT_DB_PATH=data/agent_memory.db
# Values: sqlite | mongodb
AGENT_DB_BACKEND=sqlite
# Only used when AGENT_DB_BACKEND=mongodb
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=langgraph_agent
# If mongodb is unavailable at startup, fallback to sqlite
MONGODB_FALLBACK_TO_SQLITE=true

# Optional observability
LANGSMITH_API_KEY=

# Optional cloud providers (require account / billing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Free local providers (no account required)
# Values: ollama | openai_compatible | huggingface
FREE_LLM_PROVIDER=ollama

# true -> always use local free provider even if cloud keys are present
FORCE_FREE_LLM=true

# Asian open-source defaults
FREE_THOUGHT_MODEL=qwen2.5:7b
FREE_REVIEW_MODEL=qwen2.5:7b
FREE_ACTION_MODEL=deepseek-r1:8b

# Ollama config
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_AUTO_START=true
OLLAMA_AUTO_START_TIMEOUT_SECONDS=25
OLLAMA_AUTO_START_RETRY_WINDOW_SECONDS=15
OLLAMA_PROBE_TIMEOUT_SECONDS=1.5
OLLAMA_TAGS_TIMEOUT_SECONDS=4
OLLAMA_CHAT_TIMEOUT_SECONDS=120
OLLAMA_CHAT_RETRIES=2
OLLAMA_BACKOFF_SECONDS=10
OLLAMA_NUM_PREDICT=160
LOCAL_RESCUE_ENABLED=true
LOCAL_SINGLE_PASS_ENABLED=true
OLLAMA_SINGLE_PASS_TIMEOUT_SECONDS=95
OLLAMA_SINGLE_PASS_HARD_TIMEOUT_SECONDS=100
OLLAMA_SINGLE_PASS_RETRIES=0
OLLAMA_SINGLE_PASS_NUM_PREDICT=96
# Optional advanced options:
# OLLAMA_TEMPERATURE=0.2
# OLLAMA_NUM_CTX=2048
# OLLAMA_NUM_THREAD=4

# Local OpenAI-compatible server config (LM Studio / vLLM / llama.cpp server)
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_API_KEY=

# Hugging Face Inference (OpenAI-compatible chat endpoint)
HUGGINGFACE_API_KEY=
HF_TOKEN=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_CHAT_TIMEOUT_SECONDS=80
HUGGINGFACE_MAX_TOKENS=220
HUGGINGFACE_TEMPERATURE=0.2

# API / frontend integration
# Comma separated origins. Use "*" for local prototyping.
CORS_ALLOW_ORIGINS=*

# Command runner hardening
COMMAND_EXECUTION_ENABLED=true
COMMAND_RUN_USE_SHELL=false
# Optional: regex allowlist for command text
# COMMAND_RUN_ALLOWLIST_REGEX=^(npm|pnpm|yarn|python|pytest|uv|git|ls|cat|echo)\\b

# Live thermal regulation (for more stable performance)
THERMAL_MONITOR_ENABLED=true
THERMAL_POLL_INTERVAL_SECONDS=2.0
THERMAL_WARNING_C=75
THERMAL_CRITICAL_C=85
THERMAL_COOLDOWN_WARN_SECONDS=0.8
THERMAL_COOLDOWN_CRITICAL_SECONDS=2.5
THERMAL_TIMEOUT_SCALE_WARNING=1.0
THERMAL_TIMEOUT_SCALE_CRITICAL=0.85
THERMAL_TIMEOUT_MIN_SECONDS=12

# Development
DEBUG=false
LOG_LEVEL=INFO
